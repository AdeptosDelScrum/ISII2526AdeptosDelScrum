@page "/Compra/CreateCompra"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateCompra> logger
@inject CompraStateContainer compraState


<h3>Create Compra</h3>

@* rental is the object that will be edited thanks to the form *@
<EditForm Model="compra" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.NombreCliente" class="form-control" id="Nombre" />
                <label for="Nombre">Nombre </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.Apellido1_cliente" class="form-control" id="Apellido1" />
                <label for="Name">Primer Apellido </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="compra.Apellido2_cliente" class="form-control" id="Apellido2" />
                <label for="Name">Segundo Apellido </label>
            </div>
        </div>
        
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select"
                             id="MetodoPago"
                             @bind-Value="compra.MetodoPagoId">
                    <option value="0">Seleccione un método</option>
                    <option value="1">Tarjeta</option>
                    <option value="2">PayPal</option>
                    <option value="3">GPay</option>
                </InputSelect>
                <label for="MetodoPago">Método de Pago</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to rent the movies*@
                <button class="btn btn-primary" type="submit" id="Submit" disabled="@compraButtonDisabled">
                    Comprar Bocadillos
                </button>
            </div>
        </div>
    </div>
    <h4>Compra detail</h4>
    <p>
        <b>Precio Total:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyCompraItems" id="ModifyBocadillos">
            Modificar Bocadillos
        </button>
    </p>
    
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo de Pan</th>
                    <th>Precio</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in compra.BocadillosComprados)
            {
                <tr id="BocadillosData_@item.Nombre">
                        <td>@item.Nombre</td>
                        <td>@item.TipoPan</td>
                    <td>@item.Precio €</td>
                    <td style="width:120px">
                            <InputNumber TValue="int"
                                         class="form-control"
                                         @bind-Value="item.Cantidad"
                                         min="1" />
                    </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to rent*@
@if (DialogIsOpen)
{
    <Dialog Caption="Bocadillos Compra"
    Message="Quieres comprar estos bocadilos?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    //rentalbutton will be disabled if there are not movies in the renting cart
    private bool compraButtonDisabled { get { return (compra.BocadillosComprados == null || compra.BocadillosComprados.Count == 0); } }
    private bool DialogIsOpen;
    private int metodoPagoSeleccionado = 0;
    private decimal TotalCost
    {
        get
        {
    
            double price = compra.BocadillosComprados.Sum(ci => ci.Precio * ci.Cantidad);
            return Convert.ToDecimal(price);
        }
    }
    private void ModifyCompraItems() {
        navigation.NavigateTo("/Compra/SelectBocadillosParaCompra");
    }
    private CompraBocadilloForCreateDTO compra => compraState.Compra;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }
    private void ActualizarDatos()
    {
        compraState.Compra.MetodoPagoId = metodoPagoSeleccionado;

    }
    private async Task OnDialogClose(bool isOk) {

        DialogIsOpen = false;
        if (isOk) {
            // Process the data introduced by the user if they are valid
            if (compra.BocadillosComprados.Count > 0) {
                try
                {
                    {
                        var compraCreada = await apiclient.CrearCompraAsync(compraState.Compra);
                    compraState.RentalProcessed();
                        navigation.NavigateTo($"/Compra/DetalleCompra/?CompraId={compraCreada.Id}");
                    }
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception)
                {
                    //we need to inform user that there was some other error while processing the request
                    messageError = "Error while processing your request, please try again later!";

                }

            }
        }
    }

    protected override async Task OnInitializedAsync() {

        if (authenticationState is not null) {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user is not null) {
                if (user.Identity is not null && user.Identity.IsAuthenticated) {
                    compra.NombreCliente = user.Identity.Name;
                }
            }
            compra.NombreCliente = compra.NombreCliente == null ? "" : compra.NombreCliente;
            compra.Apellido1_cliente = compra.Apellido1_cliente == null ? "" : compra.Apellido1_cliente;

        }
    }


    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
 }}