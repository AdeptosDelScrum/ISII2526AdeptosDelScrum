@page "/bonos/select"

@using AppForSEII2526.API.DTOs
@using System.Net.Http.Json
@inject HttpClient Http
@inject ILogger<SelectBonoBocadillo> logger
@inject NavigationManager nav

<h3>Bonos disponibles</h3>

<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@string.IsNullOrEmpty(errors)">
        <p>@errors</p>
    </div>

    <div class="row g-2 mb-3">
        <div class="col">
            <label class="form-label">tipo (vegano | vegetariano | sin gluten | normal)</label>
            <input class="form-control" @bind="tipo" placeholder="normal" />
        </div>
        <div class="col">
            <label class="form-label">search (nombre)</label>
            <input class="form-control" @bind="search" placeholder="Mixto" />
        </div>
        <div class="col-auto align-self-end">
            <button class="btn btn-primary" @onclick="SearchBonos">Buscar</button>
        </div>
    </div>

    @if (bonos is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover" id="TableOfBonos">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>nBocadillos</th>
                        <th>PVP</th>
                        <th>Stock</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in bonos)
                    {
                        <tr id="Bono_@b.BonoId">
                            <td>@b.Nombre</td>
                            <td>@b.NombreTipo</td>
                            <td>@b.NBocadillos</td>
                            <td>@b.Pvp</td>
                            <td>@b.CantidadDisponible</td>
                            <td>
                                <button class="btn btn-outline-secondary" @onclick="@(() => Add(b))">Añadir</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<BonoBocadilloDTO>? bonos;
    private readonly List<BonoBocadilloDTO> seleccion = new();

    private string? tipo;
    private string? search;
    private string errors = "";

    protected override async Task OnInitializedAsync()
    {
        await SearchBonos();
    }

    private async Task SearchBonos()
    {
        try
        {
            var url = "/api/bonosbocadillo/GetBonosDisponiblesSelect";
            var qs = new List<string>();
            if (!string.IsNullOrWhiteSpace(tipo))   qs.Add($"tipo={Uri.EscapeDataString(tipo)}");
            if (!string.IsNullOrWhiteSpace(search)) qs.Add($"search={Uri.EscapeDataString(search)}");
            if (qs.Count > 0) url += "?" + string.Join("&", qs);

            bonos = await Http.GetFromJsonAsync<List<BonoBocadilloDTO>>(url) ?? new();
            errors = "";
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "error llamando a GetBonosDisponiblesSelect");
            errors = "Error llamando a la API";
            bonos = new();
        }
    }

    private void Add(BonoBocadilloDTO b)
    {
        if (!seleccion.Any(x => x.BonoId == b.BonoId))
            seleccion.Add(b);
        // aqui puedes navegar o mostrar un carrito
        // nav.NavigateTo("/otra-ruta");
    }
}

