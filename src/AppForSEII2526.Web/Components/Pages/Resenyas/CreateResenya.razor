@page "/resenyas/createresenya"

@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateResenya> logger
@inject ResenyaStateContainer resenyaState

<h3>Datos de reseña</h3>

@* rental is the object that will be edited thanks to the form *@
<EditForm Model="resenya" OnValidSubmit="OpenDialog">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Name" class="form-control" id="Name" />
                <label for="Name">Nombre </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Title" class="form-control" id="Title" />
                <label for="Title">Título </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Description" class="form-control" id="Description" />
                <label for="Description">Descripción</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputNumber @bind-Value="resenya.Rate" class="form-control" id="Rate" />
                <label for="Rate">Valoración</label>
            </div>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Nombre_cliente" class="form-control" id="NameClient" />
                <label for="Name">Nombre Cliente</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Apellido1_cliente" class="form-control" id="Apellido1" />
                <label for="Title">Primer Apellido </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="resenya.Apellido2_cliente" class="form-control" id="Apellido2" />
                <label for="Description">Segundo Apellido </label>
            </div>
        </div>
    </div>
    <div class="col-md">
        <div class="form-floating">
            @*this button will be used to ask the user if he want to proceed to rent the movies*@
            <button class="btn btn-primary" type="submit" id="Submit">
                Reseñar los bocadillos
            </button>
        </div>
    </div>

    <h4>Detalles de reseña</h4>
    <p>
        <button class="btn btn-outline-primary" type="submit" @onclick="ModifyResenyaItems" id="ModifyBocadillos">
            Modificar Bocadillos
        </button>
    </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfBocadillos">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Tamaño</th>
                    <th>Puntuación</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in resenya.Lineas)
                {
                    <tr id="MovieData_@item.Bocadillo.Name">
                        <td>@item.Bocadillo.Name</td>
                        <td>@item.Bocadillo.Pvp</td>
                        <td>@item.Bocadillo.TamanyoBocadillo</td>
                        <td><InputNumber @bind-Value="item.Puntuacion" class="form-control" id="@($"puntuacion_{item.Bocadillo.Name}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>
@*a modal popup dialog for checking if user wants to proceed to rent*@
@if (DialogIsOpen)
{
    <Dialog Caption="Reseñar bocadillos"
    Message="Quieres reseñar estos bocadillos?"
    OnClose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>
}

@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private bool DialogIsOpen;
    private object? errors;
    private ResenyaDTO resenya => resenyaState.Resenya;

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {

        DialogIsOpen = false;
        if (isOk)
        {
            if (resenya.Lineas.Count > 0)
            {
                try
                {
                    var resenyado = await apiclient.PostResenyaAsync(resenya);
                    resenyaState.ResenyaProcessed();
                    Console.WriteLine("ID DEL CREATE");
                    Console.WriteLine(resenyado.Id);
                    navigation.NavigateTo($"/resenyas/detailsresenya/?Id={resenyado.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception)
                {
                    //we need to inform user that there was some other error while processing the request
                    messageError = "Error while processing your request, please try again later!";

                }

            }
        }
    }

    private void ModifyResenyaItems()
    {
        navigation.NavigateTo("/resenyas/SelectBocadillosParaResenyar");
    }
}
